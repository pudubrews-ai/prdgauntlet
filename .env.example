# PRD Gauntlet MCP Server - Environment Variables
# Copy this file to .env and fill in your API keys

# Required: API keys for each provider
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...

# Optional: Override default configuration
# DEBUG=true                    # Enable debug logging (default: false)
# MAX_ROUNDS_PER_MODEL=5        # Max debate rounds per critic (default: 5)
# MAX_TOTAL_TOKENS=100000       # Token cap (default: unlimited)
# MAX_ESTIMATED_COST=1.00       # Cost cap in USD (default: unlimited)
# MAX_CONCURRENT_JOBS=3         # Max concurrent gauntlet jobs (default: 3)
